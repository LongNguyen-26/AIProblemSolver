<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17.0.6"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.ui.controller.ResultController"
      spacing="10.0"
      styleClass="tab-content">
    <padding>
        <Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label text="Sinh code mau" styleClass="section-title"/>
            <HBox spacing="10.0">
                <ComboBox fx:id="codeTypeCombo" prefWidth="125.0" promptText="Loai code"/>
                <ComboBox fx:id="languageCombo" prefWidth="125.0" promptText="Ngon ngu"/>
                <Button text="Sinh code"
                        onAction="#onGenerateCode"
                        styleClass="btn-primary"/>
            </HBox>
        </VBox>
    </HBox>

    <SplitPane orientation="HORIZONTAL" dividerPositions="0.6" VBox.vgrow="ALWAYS">
        <VBox minWidth="420.0" spacing="6.0">
            <Label text="Source Code:" styleClass="field-label"/>
            <TextArea fx:id="codeArea"
                      styleClass="code-editor"
                      wrapText="false"
                      VBox.vgrow="ALWAYS"/>
            <HBox spacing="10.0">
                <Button text="Chay tat ca test"
                        onAction="#onRunAllTests"
                        maxWidth="Infinity"
                        styleClass="btn-primary"
                        HBox.hgrow="ALWAYS"/>
                <Button text="Xuat bao cao"
                        onAction="#onExportReport"
                        styleClass="btn-secondary"/>
            </HBox>
        </VBox>

        <VBox minWidth="320.0" spacing="6.0">
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Ket qua:" styleClass="field-label"/>
                <Label fx:id="summaryLabel" text="-" styleClass="summary-label"/>
            </HBox>
            <TableView fx:id="resultTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="rTcIdCol" text="TC" prefWidth="70.0"/>
                    <TableColumn fx:id="rVerdictCol" text="Verdict" prefWidth="80.0"/>
                    <TableColumn fx:id="rTimeCol" text="Time" prefWidth="75.0"/>
                    <TableColumn fx:id="rDiffCol" text="Diff" prefWidth="150.0"/>
                </columns>
            </TableView>
            <Label text="Explanation:" styleClass="field-label"/>
            <TextArea fx:id="explanationArea"
                      editable="false"
                      prefRowCount="4"
                      wrapText="true"/>
        </VBox>
    </SplitPane>
</VBox>
